# OpenAI — для OCR наклеек (GPT-4o-mini) и транскрипции голоса (Whisper)
# Если не нужно — оставьте пустым
OPENAI_API_KEY=sk-proj-...

# ── Битрикс24 ─────────────────────────────────────────────────────────────────

# URL входящего вебхука (Разработчикам → Другое → Входящий вебхук)
# Права: disk, lists
